<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Payment Confirmed</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            line-height: 1.6;
            color: #333;
            background-color: #f4f6f9;
            margin: 0;
            padding: 0;
        }
        .container {
            max-width: 600px;
            margin: 40px auto;
            background: #ffffff;
            border-radius: 12px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.08);
            overflow: hidden;
        }
        .header {
            background: linear-gradient(135deg, #10b981, #059669);
            padding: 30px;
            text-align: center;
        }
        .header h1 {
            color: #ffffff;
            margin: 0;
            font-size: 24px;
        }
        .header .logo {
            font-size: 32px;
            margin-bottom: 8px;
        }
        .body {
            padding: 30px;
        }
        .pin-box {
            background: #f3f4f6;
            border-radius: 8px;
            padding: 20px;
            text-align: center;
            margin: 20px 0;
            border: 2px dashed #10b981;
        }
        .pin {
            font-size: 36px;
            font-weight: 700;
            letter-spacing: 8px;
            color: #10b981;
            font-family: monospace;
        }
        .details {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            margin: 16px 0;
        }
        .detail-item {
            background: #f9fafb;
            padding: 10px 12px;
            border-radius: 6px;
        }
        .detail-item .label {
            font-size: 11px;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .detail-item .value {
            font-weight: 600;
            font-size: 15px;
        }
        .btn {
            display: inline-block;
            padding: 12px 30px;
            background: #10b981;
            color: #ffffff;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            margin: 8px 0;
        }
        .btn:hover {
            background: #059669;
        }
        .footer {
            background: #f9fafb;
            padding: 20px;
            text-align: center;
            font-size: 12px;
            color: #6b7280;
            border-top: 1px solid #e5e7eb;
        }
        .footer a {
            color: #10b981;
            text-decoration: none;
        }
        @media (max-width: 480px) {
            .details {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="logo">📚</div>
            <h1>EduCamLab</h1>
            <p style="color: rgba(255,255,255,0.9); margin: 0;">Payment Confirmed ✅</p>
        </div>
        
        <div class="body">
            <h2>Hello <%= firstname %>!</h2>
            <p>Your payment has been confirmed and your <%= plan %> subscription is now active! 🎉</p>
            
            <div class="pin-box">
                <p style="font-size: 14px; color: #065f46; margin-bottom: 8px;">🔑 Your Login PIN</p>
                <div class="pin"><%= pin %></div>
                <p style="font-size: 12px; color: #065f46; margin-top: 8px;">Use this PIN to login to your account</p>
            </div>
            
            <div class="details">
                <div class="detail-item">
                    <div class="label">Plan</div>
                    <div class="value"><%= plan %></div>
                </div>
                <div class="detail-item">
                    <div class="label">Amount</div>
                    <div class="value"><%= amount %> XAF</div>
                </div>
                <div class="detail-item">
                    <div class="label">Transaction ID</div>
                    <div class="value" style="font-size: 12px; word-break: break-all;"><%= transactionId %></div>
                </div>
                <div class="detail-item">
                    <div class="label">Valid Until</div>
                    <div class="value"><%= expiresAt %></div>
                </div>
            </div>
            
            <p style="text-align: center; margin: 20px 0;">
                <a href="<%= frontendUrl %>/login.html" class="btn">Login Now</a>
            </p>
            
            <hr style="border: none; border-top: 1px solid #e5e7eb; margin: 20px 0;">
            
            <p style="font-size: 13px; color: #6b7280;">Keep your PIN secure. Do not share it with anyone.</p>
        </div>
        
        <div class="footer">
            <p>&copy; <%= year %> EduCamLab. All rights reserved.</p>
            <p>
                <a href="<%= frontendUrl %>/policy/privacy.html">Privacy Policy</a> |
                <a href="<%= frontendUrl %>/policy/terms.html">Terms of Service</a>
            </p>
        </div>
    </div>
</body>
</html>