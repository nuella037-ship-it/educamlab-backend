{
  "name": "educamlab-backend",
  "version": "2.0.0",
  "description": "EduCamLab Learning Platform Backend API - Production",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "node src/config/migrate.js",
    "migrate:reset": "node src/config/migrate.js --reset",
    "seed": "node scripts/seed.js",
    "seed:admin": "node scripts/make-admin.js",
    "backup": "node scripts/backup.js",
    "health": "node scripts/health.js",
    "test": "node scripts/test.js",
    "lint": "eslint src/**/*.js",
    "format": "prettier --write src/**/*.js",
    "logs": "tail -f logs/app.log",
    "logs:error": "tail -f logs/error.log"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "ejs": "^6.0.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.0",
    "helmet": "^7.0.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.0",
    "node-cron": "^4.5.0",
    "nodemailer": "^9.0.1",
    "uuid": "^14.0.1",
    "winston": "^3.19.0",
    "xss": "^1.0.14"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "author": "EduCamLab Team",
  "license": "MIT"
}
